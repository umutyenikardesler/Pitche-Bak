{
  "expo": {
    "name": "SahayaBak",
    "slug": "Pitche-Bak",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/app.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.tumurelsedrakiney.PitcheBak",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "config": {
        "googleMapsApiKey": "AIzaSyC9VGm56IFnVAYEYKoPnPt3eGJ3_NMwPB4"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yakınınızdaki sahaları göstermek ve konuma göre sıralamak için konumunuza ihtiyaç var.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "tr",
        "CFBundleLocalizations": ["tr", "en"],
        "CFBundleDisplayName": "SahayaBak",
        "LSApplicationQueriesSchemes": [
          "fb",
          "fbapi",
          "fbauth2",
          "fb-messenger-api",
          "fbshareextension",
          "facebook-stories",
          "instagram",
          "whatsapp"
        ]
      }
    },
    "android": {
      "label": "SahayaBak",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC9VGm56IFnVAYEYKoPnPt3eGJ3_NMwPB4"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tumurelsedrakiney.pitchebak"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app.png",
          "color": "#16a34a",
          "sounds": []
        }
      ],
      [
        "react-native-share",
        {
          "ios": [
            "fb",
            "instagram",
            "whatsapp"
          ],
          "android": [
            "com.facebook.katana",
            "com.instagram.android",
            "com.whatsapp"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bcaeff72-7e2a-4511-8ad1-73798a478d1a"
      },
      "webBaseUrl": "https://sahayabak.com",
      "facebookAppId": "1885487315494376",
      "admob": {
        "bannerUnitIdIos": "ca-app-pub-1347758252118471/7078957007",
        "bannerUnitIdAndroid": "ca-app-pub-1347758252118471/9999190850"
      }
    }
  }
}
